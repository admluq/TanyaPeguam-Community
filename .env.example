# =====================================================
# tptree — Environment Variables (Example)
# =====================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to git.
# =====================================================

# ─── Database ───────────────────────────────────────
# Local Postgres example:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tptree"
# Supabase example (production):
#   DATABASE_URL="postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tptree"

# ─── Site config ────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="TanyaPeguam"

# ─── Phase 4: Live preview engines ──────────────────
# (Not required until preview features built)

# ScreenshotOne API (for website preview)
# Get free 100/month at https://screenshotone.com
SCREENSHOTONE_API_KEY=""

# Facebook Graph API (for FB stats)
# Setup at https://developers.facebook.com
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ─── Phase 3: Authentication (admin panel) ──────────
# (Not required until auth features built)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
