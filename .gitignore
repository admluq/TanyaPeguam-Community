# =====================================================
# tptree — .gitignore
# =====================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
/.next/
/out/
build/
dist/

# Production
*.tsbuildinfo
next-env.d.ts

# Environment files (NEVER commit)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Prisma
# (we DO commit migrations, but not the temporary client cache)
prisma/migrations/dev.db*

# Vercel
.vercel/

# Supabase
supabase/.branches
supabase/.temp

# TypeScript
*.tsbuildinfo

# Coverage
coverage/
.nyc_output

# Misc
.turbo
