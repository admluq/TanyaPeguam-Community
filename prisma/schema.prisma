// =====================================================
// TanyaPeguam Donna AI — Prisma Schema
// Admin-Backwards Architecture
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// Auth — NextAuth v5 required models
// ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  accounts      Account[]
  sessions      Session[]

  // Link to lawyer profile
  lawyerProfile LawyerProfile?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─────────────────────────────────────────────────────
// LawyerProfile — The core identity for each lawyer
// Every user with a lawyer role has exactly one profile
// ─────────────────────────────────────────────────────

model LawyerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile identity
  slug      String   @unique // URL-safe identifier
  firmName  String?  // e.g. "Arif Azmi & Co"
  bio       String?  @db.Text

  // Social & contact links (JSON structure)
  // { whatsapp: "+60123456789", linkedin: "url", website: "url", ... }
  socialLinks Json?

  // Public visibility
  isPublic  Boolean  @default(false)

  // Relations
  donnaConfig  DonnaConfig?
  donnaBridges DonnaBridge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

// ─────────────────────────────────────────────────────
// DonnaConfig — AI orchestration rules for the lawyer
// Linked to LawyerProfile, controls multi-agent behavior
// ─────────────────────────────────────────────────────

enum DonnaPersonality {
  PROFESSIONAL
  SOFT
  STRICT
}

model DonnaConfig {
  id               String   @id @default(cuid())
  profileId        String   @unique
  profile          LawyerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Knowledge & behavior
  kbContext        String?  @db.Text // Knowledge base context for the AI
  personality      DonnaPersonality @default(PROFESSIONAL)

  // Triage rules (JSON structure)
  // { deflectPatterns: [...], practiceAreas: [...], urgencyFlags: [...] }
  triageRules      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

// ─────────────────────────────────────────────────────
// DonnaBridge — Session logger for intakes
// Each bridge represents one conversation/intake session
// ─────────────────────────────────────────────────────

enum BridgeStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  ESCALATED
}

model DonnaBridge {
  id               String   @id @default(cuid())
  profileId        String
  profile          LawyerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Session tracking
  shortCode        String   @unique // Short identifier for sharing
  status           BridgeStatus @default(ACTIVE)

  // Conversation data
  transcript       String?  @db.Text // Full conversation log
  triageResult     Json?    // Result of intake triage

  // Metadata
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  practiceArea     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([shortCode])
  @@index([status])
}
