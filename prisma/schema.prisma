// =====================================================
// TanyaPeguam Donna AI — Prisma Schema
// Admin-Backwards Architecture
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// Auth — NextAuth v5 required models
// ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  accounts      Account[]
  sessions      Session[]

  // Link to lawyer profile
  lawyerProfile LawyerProfile?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─────────────────────────────────────────────────────
// LawyerProfile — The core identity for each lawyer
// Digital Card with comprehensive firm & contact details
// ─────────────────────────────────────────────────────

enum LawyerStatus {
  AVAILABLE
  BUSY
  AWAY
  OFFLINE
}

model LawyerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile identity
  slug      String   @unique // URL-safe identifier
  username  String?  // Display username for Digital Card

  // Peguam (Lawyer Details)
  status    LawyerStatus @default(AVAILABLE)
  position  String?  // e.g. "Founder / Principal Lawyer"
  bio       String?  @db.Text // Professional bio (100-word limit)

  // Firma (Firm Details)
  firmName  String?  // e.g. "Arif Azmi & Co"
  firmPhone String?  // Firm phone number
  firmWebsite String? // Firm website URL
  firmAddress String? @db.Text // Firm physical address
  googleMapsUrl String? // Google Maps link
  googleReviewUrl String? // Google Reviews link

  // Media Sosial Profesional (Professional Social Links)
  // { facebook: "url", instagram: "handle", tiktok: "handle", linkedin: "url", ... }
  socialLinks Json?

  // Profile picture (base64 or URL; client-side resized to ≤200px before upload)
  avatarUrl String?  @db.Text

  // Public visibility
  isPublic  Boolean  @default(false)

  // Setup tracking
  setupCompleted Boolean @default(false) // Tracks if user completed initial setup flow

  // Relations
  donnaConfig        DonnaConfig?
  legalServiceConfig LegalServiceConfig?
  donnaBridges       DonnaBridge[]
  donnaInquiries     DonnaInquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

// ─────────────────────────────────────────────────────
// DonnaConfig — AI orchestration rules for the lawyer
// Linked to LawyerProfile, controls multi-agent behavior
// ─────────────────────────────────────────────────────

enum DonnaPersonality {
  PROFESSIONAL
  SOFT
  STRICT
}

model DonnaConfig {
  id               String   @id @default(cuid())
  profileId        String   @unique
  profile          LawyerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Knowledge & behavior
  kbContext        String?  @db.Text // Knowledge base context for the AI
  personality      DonnaPersonality @default(PROFESSIONAL)

  // Triage rules (JSON structure)
  // { deflectPatterns: [...], practiceAreas: [...] }
  triageRules      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

// ─────────────────────────────────────────────────────
// LegalServiceConfig — Lawyer's service & operational config
// Last agent before orchestrator triage
// ─────────────────────────────────────────────────────

enum ServiceTier {
  LOW
  MEDIUM
  HIGH
}

enum ModKonsultasi {
  PERCUMA
  BERBAYAR
}

model LegalServiceConfig {
  id        String   @id @default(cuid())
  profileId String   @unique
  profile   LawyerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Jurisdiction
  negeriOperasi String?        // Main operating state
  badanPeguam   String[]       // Bar body memberships

  // Operating hours & fees
  waktuOperasi              String?       @default("isnin-jumaat-9-5")
  modKonsultasi             ModKonsultasi @default(PERCUMA)
  yuranKonsultasi           Float?
  yuranKecemasan            Float?
  yuranVideoMeeting         Float?
  yuranVideoMeetingKecemasan Float?
  yuranMeetingFizikal       Float?
  yuranMeetingFizikalKecemasan Float?

  // Inquiry contact
  emelPertanyaan String?

  // Service tier (multi-select array)
  tierPerkhidmatan String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

// ─────────────────────────────────────────────────────
// DonnaInquiry — Scored intake record
// Created when Donna completes an intake session
// Tracks scoring, status, and accept/reject tokens
// ─────────────────────────────────────────────────────

enum InquiryStatus {
  PENDING
  EMAILED
  ACCEPTED
  REJECTED
  DEFLECTED
}

model DonnaInquiry {
  id               String        @id @default(cuid())
  profileId        String
  profile          LawyerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Client details
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  practiceArea     String?
  issueSummary     String?       @db.Text

  // Full transcript
  transcript       String?       @db.Text

  // Donna scoring output
  concreteScore    Int           @default(0)   // 0–100
  urgencyTag       String?       // LOW / MEDIUM / HIGH / CRITICAL
  sophistication   String?       // LAYPERSON / INFORMED / SOPHISTICATED
  suggestedTier    String?       // FREE_CONSULT / PAID_CONSULT / FULL_RETAINER
  deflected        Boolean       @default(false)

  // Accept / Reject magic tokens
  acceptToken      String        @unique @default(cuid())
  rejectToken      String        @unique @default(cuid())

  // Status lifecycle
  status           InquiryStatus @default(PENDING)
  emailSentAt      DateTime?
  acceptedAt       DateTime?
  rejectedAt       DateTime?

  // Optional link to a DonnaBridge session (one-to-one)
  bridgeId         String?       @unique
  bridge           DonnaBridge?  @relation(fields: [bridgeId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([profileId])
  @@index([status])
  @@index([acceptToken])
  @@index([rejectToken])
}

// ─────────────────────────────────────────────────────
// DonnaBridge — Session logger for intakes
// Each bridge represents one conversation/intake session
// ─────────────────────────────────────────────────────

enum BridgeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  DELETED
  ESCALATED
}

model DonnaBridge {
  id               String   @id @default(cuid())
  profileId        String
  profile          LawyerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Session tracking
  shortCode        String   @unique // Short identifier for sharing
  status           BridgeStatus @default(ACTIVE)
  createdBy        String   @default("lawyer") // 'lawyer' | 'system' | 'inbound'

  // ── IMMUTABLE Source of Truth ─────────────────────
  // The original FB question + the lawyer's pre-vet answer.
  // These fields MUST NOT be updated after creation — enforced by
  // Prisma middleware in lib/db.ts.
  // Nullable for backfill compatibility; required at lib/bridge.ts layer.
  initialQuestion  String?  @db.Text
  initialAnswer    String?  @db.Text

  // ── APPEND-ONLY mutable chat log ──────────────────
  // Array of turns: [{ role: 'user'|'assistant'|'system', content, ts, turnIndex, toolCalls? }]
  // Only mutated via lib/bridge.ts.appendTurn(). Never overwritten wholesale.
  chatTranscript   Json?    @default("[]")

  // ── Agent B (triage) output ───────────────────────
  triageResult     Json?    // { urgency, criticalFlag, deflected, mustHaves, escalationActions }

  // ── Agent C (summarizer) output ───────────────────
  summary          String?  @db.Text

  // Resume key: server-issued opaque token for widget hydration on refresh
  conversationId   String?  @unique

  // Metadata (extracted by Agent A's tools, not free-form)
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  practiceArea     String?

  // ── DEPRECATED (kept for backfill, drop in next migration) ─────
  // Old String transcript field — used to hold either plain initial-context text
  // or JSON-stringified {question, answer, createdBy}. Migrated into
  // initialQuestion/initialAnswer by scripts/backfill-bridges.mjs.
  transcript       String?  @db.Text

  // ── Server-authoritative agent state ─────────────────────────
  // chatPhase is NEVER supplied by the client — it is always read from and
  // written to by the server. This prevents clients from skipping intake steps.
  // Values map to the donna-chat state machine: start | name_phone | email_opt |
  // q1 | q2 | q3 | q4 | q5 | done
  chatPhase        String   @default("start")
  agentTurnCount   Int      @default(0)

  // Accumulated entity extraction from Agent A (merged across turns)
  // { name?, phone?, email?, issueDetails?, docsAcknowledged?, consultation?, urgency?, remarks? }
  extractedEntities Json?

  // Back-reference to scored inquiry
  inquiry          DonnaInquiry?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([shortCode])
  @@index([status])
  @@index([conversationId])
  @@index([chatPhase])
}
