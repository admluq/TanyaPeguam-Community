// =====================================================
// tptree — Prisma Schema
// =====================================================
// Multi-tenant lawyer profile pages
// Each Profile has many Links (social, contact, web)
// Each Link can have CachedPreview for live data
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// Profile — the lawyer's profile page
// URL: tanyapeguam.com/[slug]
// ─────────────────────────────────────────────────────
model Profile {
  id        String   @id @default(cuid())
  slug      String   @unique // URL slug, e.g. "datukwanazmir"
  isActive  Boolean  @default(true)
  isVerified Boolean @default(false) // shows "Profil Disahkan" badge

  // Identity
  name      String   // "Datuk Wan Azmir"
  title     String   // "Peguam Kanan"
  firm      String?  // "HWAM" — short name for header
  firmFull  String?  // "Hafarizam Wan & Aisha Mubarak" — full name
  monogram  String?  // "WA" — for avatar circle

  // Location & status
  location  String   // "Kuala Lumpur"
  status    Status   @default(AVAILABLE)

  // Practice areas (badges)
  practiceAreas String[] // ["Korporat & Sivil", "Litigasi"]

  // Bio (optional, for SEO meta description)
  bio       String?  @db.Text

  // SEO
  metaTitle       String?
  metaDescription String?

  // Relations
  links     Link[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

enum Status {
  AVAILABLE
  BUSY
  AWAY
  OFFLINE
}

// ─────────────────────────────────────────────────────
// Link — individual link card on profile
// E.g. WhatsApp, LinkedIn, TikTok, Website
// ─────────────────────────────────────────────────────
model Link {
  id           String   @id @default(cuid())
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  type         LinkType // determines icon, color, expand behavior
  label        String   // "Hubungi Kami", "LinkedIn"
  subtitle     String?  // "WhatsApp · Lokasi · Ulasan"
  url          String?  // optional — some links don't go anywhere (e.g. AI chat)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)

  // Custom data per link type (JSON)
  // - WHATSAPP: { phone, prefilledMessage }
  // - WEBSITE: { domain, screenshotUrl }
  // - LINKEDIN: { handle, manualPosts: [...] }
  // - TIKTOK: { handle, videoIds: [...] }
  // - FACEBOOK: { pageId, stats: { likes, followers, rating } }
  // - INSTAGRAM: { handle }
  // - TWITTER: { handle }
  // - AI_CHAT: { agentId, modelName }
  metadata     Json?

  // Cached fetched data (refreshed via cron)
  cachedPreview CachedPreview?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([profileId])
  @@index([type])
}

enum LinkType {
  WHATSAPP
  WEBSITE
  LINKEDIN
  INSTAGRAM
  FACEBOOK
  TIKTOK
  TWITTER
  YOUTUBE
  EMAIL
  PHONE
  AI_CHAT
  CUSTOM
}

// ─────────────────────────────────────────────────────
// CachedPreview — server-side cache for live previews
// Refreshed via cron job (e.g. every 24h)
// ─────────────────────────────────────────────────────
model CachedPreview {
  id          String   @id @default(cuid())
  linkId      String   @unique
  link        Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  // Preview data (varies by link type)
  // - WEBSITE: { ogTitle, ogDescription, ogImage, screenshotUrl }
  // - LINKEDIN: { posts: [{ content, postedAt, url }] }
  // - TIKTOK: { videos: [{ id, thumbnail, caption, views }] }
  // - FACEBOOK: { likes, followers, rating, latestPost }
  data        Json

  // Cache control
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
  fetchStatus FetchStatus @default(SUCCESS)
  errorMessage String?

  @@index([expiresAt])
}

enum FetchStatus {
  SUCCESS
  FAILED
  STALE
}

// ─────────────────────────────────────────────────────
// AnalyticsEvent — track clicks per link (Phase 5)
// ─────────────────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(cuid())
  profileId String
  linkId    String?
  eventType String   // "page_view", "link_click", "expand"

  // Visitor metadata (anonymized)
  country   String?
  device    String?
  referrer  String?

  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@index([linkId, createdAt])
}
