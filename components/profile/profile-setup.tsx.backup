'use client';

import { useState, useTransition } from 'react';
import { useRouter } from 'next/navigation';
import { User, Mail, Phone, MapPin, Building, Briefcase, Save, Loader2, Plus, Trash2, ExternalLink, Globe, MessageCircle, Linkedin, Instagram, Facebook, Twitter, Youtube } from 'lucide-react';

type Profile = {
  id?: string;
  // Lawyer Details
  name?: string;
  title?: string;
  username?: string;
  status?: 'AVAILABLE' | 'BUSY' | 'AWAY' | 'OFFLINE';
  bio?: string;
  phone?: string;
  whatsappLink?: string;
  hasValidSAPC?: boolean;
  sapcYear?: string;
  
  // Firm Details
  firm?: string;
  firmFull?: string;
  firmPhone?: string;
  firmWebsite?: string;
  firmAddress?: string;
  firmGoogleLocation?: string;
  firmGoogleReview?: string;
  
  // Professional Socials
  socials?: {
    id?: string;
    type: 'FACEBOOK' | 'TIKTOK' | 'INSTAGRAM' | 'LINKEDIN';
    url: string;
    isActive: boolean;
  }[];
  
  // Existing fields for compatibility
  monogram?: string;
  location?: string;
  practiceAreas?: string[];
  isVerified?: boolean;
  isActive?: boolean;
  slug?: string;
  metaTitle?: string;
  metaDescription?: string;
  links?: any[];
};

export function ProfileSetup({ initialProfile }: { initialProfile: Profile | null }) {
  const router = useRouter();
  const [isPending, startTransition] = useTransition();
  const [saved, setSaved] = useState(false);

  const [profile, setProfile] = useState<Profile>({
    // Core Information
    name: initialProfile?.name || '',
    title: initialProfile?.title || '',
    firm: initialProfile?.firm || '',
    location: initialProfile?.location || '',
    practiceAreas: initialProfile?.practiceAreas || [],
    bio: initialProfile?.bio || '',
    status: initialProfile?.status || 'AVAILABLE',
    
    // Contact Information
    phone: initialProfile?.phone || '',
    whatsappLink: initialProfile?.whatsappLink || '',
    firmPhone: initialProfile?.firmPhone || '',
    firmWebsite: initialProfile?.firmWebsite || '',
    firmAddress: initialProfile?.firmAddress || '',
    
    // Social Media
    socials: initialProfile?.socials || [],
    
    // Professional Details
    hasValidSAPC: initialProfile?.hasValidSAPC || false,
    sapcYear: initialProfile?.sapcYear || '',
    
    // System Fields
    monogram: initialProfile?.monogram || '',
    isVerified: initialProfile?.isVerified || false,
    isActive: initialProfile?.isActive !== false,
    slug: initialProfile?.slug || '',
    metaTitle: initialProfile?.metaTitle || '',
    metaDescription: initialProfile?.metaDescription || '',
    links: initialProfile?.links || [],
  });

  const [newLink, setNewLink] = useState({
    type: 'WEBSITE',
    label: '',
    url: '',
  });

  const [newSocial, setNewSocial] = useState({
    type: 'FACEBOOK' as const,
    url: '',
  });

  function update(key: keyof Profile, value: string | string[] | boolean) {
    setProfile((prev) => ({ ...prev, [key]: value }));
  }

  function addSocial() {
    if (newSocial.url) {
      const social = {
        id: Date.now().toString(),
        type: newSocial.type,
        url: newSocial.url,
        isActive: true,
      };
      setProfile((prev) => ({
        ...prev,
        socials: [...(prev.socials || []), social],
      }));
      setNewSocial({ type: 'FACEBOOK', url: '' });
    }
  }

  function removeSocial(id: string) {
    setProfile((prev) => ({
      ...prev,
      socials: prev.socials?.filter((social) => social.id !== id) || [],
    }));
  }

  function getSocialIcon(type: string) {
    switch (type) {
      case 'FACEBOOK': return <Facebook size={16} />;
      case 'TIKTOK': return <Youtube size={16} />;
      case 'INSTAGRAM': return <Instagram size={16} />;
      case 'LINKEDIN': return <Linkedin size={16} />;
      default: return <ExternalLink size={16} />;
    }
  }

  function addLink() {
    if (newLink.label && newLink.url) {
      const link = {
        id: Date.now().toString(), // temporary ID
        type: newLink.type,
        label: newLink.label,
        url: newLink.url,
        displayOrder: (profile.links?.length || 0),
        isActive: true,
      };
      setProfile((prev) => ({
        ...prev,
        links: [...(prev.links || []), link],
      }));
      setNewLink({ type: 'WEBSITE', label: '', url: '' });
    }
  }

  function removeLink(id: string) {
    setProfile((prev) => ({
      ...prev,
      links: prev.links?.filter((link) => link.id !== id) || [],
    }));
  }

  function getLinkIcon(type: string) {
    switch (type) {
      case 'WEBSITE': return <Globe size={16} />;
      case 'WHATSAPP': return <MessageCircle size={16} />;
      case 'LINKEDIN': return <Linkedin size={16} />;
      case 'INSTAGRAM': return <Instagram size={16} />;
      case 'FACEBOOK': return <Facebook size={16} />;
      case 'TWITTER': return <Twitter size={16} />;
      case 'YOUTUBE': return <Youtube size={16} />;
      case 'EMAIL': return <Mail size={16} />;
      case 'PHONE': return <Phone size={16} />;
      default: return <ExternalLink size={16} />;
    }
  }

  function submit() {
    startTransition(async () => {
      const res = await fetch('/api/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(profile),
      });
      if (res.ok) {
        setSaved(true);
        setTimeout(() => setSaved(false), 3000);
        router.refresh();
      }
    });
  }

  const practiceAreaOptions = [
    'Defamasi & Reputasi',
    'Probet & Harta Pusaka',
    'Hartanah',
    'Pekerjaan & Buruh',
    'Jenayah',
    'Keluarga & Perkahwinan',
    'Korporat & Perniagaan',
    'Sivil Am',
  ];

  return (
    <div className="max-w-2xl mx-auto p-6 space-y-8">
      <div className="flex items-center justify-between mb-8">
        <div>
          <h1 className="text-2xl font-bold text-text-primary mb-2">Profil Peguam & Firma</h1>
          <p className="text-text-secondary text-sm">
            Kemaskini maklumat profesional anda untuk dipaparkan di profil awam.
          </p>
        </div>
        {saved && (
          <div className="flex items-center gap-2 text-sm text-[#34d399] bg-[rgba(52,211,153,0.1)] px-4 py-2 rounded-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
            </svg>
            Profil berjaya disimpan
          </div>
        )}
      </div>

      {/* Basic Information */}
      <div className="space-y-6">
        <div className="flex items-center gap-2 mb-4">
          <User size={20} className="text-lia-light" />
          <h2 className="text-lg font-semibold text-text-primary">Maklumat Asas</h2>
        </div>
        
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Nama Penuh
            </label>
            <input
              type="text"
              value={profile.name}
              onChange={(e) => update('name', e.target.value)}
              placeholder="Masukkan nama penuh anda"
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Jawatan/Gelar
            </label>
            <input
              type="text"
              value={profile.title}
              onChange={(e) => update('title', e.target.value)}
              placeholder="Contoh: Peguam Cara Negara"
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Nama Firma
            </label>
            <input
              type="text"
              value={profile.firm}
              onChange={(e) => update('firm', e.target.value)}
              placeholder="Nama firma guaman"
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Lokasi
            </label>
            <input
              type="text"
              value={profile.location}
              onChange={(e) => update('location', e.target.value)}
              placeholder="Bandar atau negeri operasi"
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>
        </div>

        <div>
          <label className="block text-sm font-medium text-text-primary mb-2">
            Bio / Perihal
          </label>
          <textarea
            value={profile.bio}
            onChange={(e) => update('bio', e.target.value)}
            rows={3}
            maxLength={100}
            placeholder="Berikan ringkasan tentang latar belakang dan pengkhususan anda... (kurang 100 perkataan)"
            className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors resize-none"
          />
          <p className="text-xs text-text-muted mt-1">{profile.bio?.length || 0}/100 perkataan</p>
        </div>

        <div>
          <label className="block text-sm font-medium text-text-primary mb-2">
            Status Ketersediaan
          </label>
          <div className="grid grid-cols-2 md:grid-cols-4 gap-2">
            {[
              { value: 'AVAILABLE', label: 'Boleh Dihubungi', color: 'text-[#34d399]' },
              { value: 'BUSY', label: 'Sibuk', color: 'text-gold' },
              { value: 'AWAY', label: 'Jauh', color: 'text-[#fb923c]' },
              { value: 'OFFLINE', label: 'Tidak Aktif', color: 'text-text-muted' },
            ].map((status) => (
              <button
                key={status.value}
                onClick={() => update('status', status.value as any)}
                className={`flex items-center justify-center gap-2 p-3 rounded-xl border text-left transition-all text-sm ${
                  profile.status === status.value
                    ? 'border-lia-border bg-lia-dim text-text-primary'
                    : 'border-border text-text-secondary hover:border-border-hover'
                }`}
              >
                <div className={`w-4 h-4 rounded-full ${status.color}`} />
                {status.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Contact & Social */}
      <div className="space-y-6">
        <div className="flex items-center gap-2 mb-4">
          <Phone size={20} className="text-lia-light" />
          <h2 className="text-lg font-semibold text-text-primary">Hubungan & Media Sosial</h2>
        </div>
        
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Telefon
            </label>
            <input
              type="tel"
              value={profile.phone}
              onChange={(e) => update('phone', e.target.value)}
              placeholder="+60 12-3456789"
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Laman Web
            </label>
            <input
              type="url"
              value={profile.firmWebsite}
              onChange={(e) => update('firmWebsite', e.target.value)}
              placeholder="https://..."
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>

          <div>
            <label className="flex items-center gap-2 text-sm">
              <input
                type="checkbox"
                checked={profile.whatsappLink === profile.phone}
                onChange={(e) => update('whatsappLink', e.target.checked ? profile.phone || '' : '')}
                className="w-4 h-4 text-lia border-border rounded focus:ring-lia"
              />
              Hubungkan ke telefon
            </label>
          </div>

          <div>
            <label className="block text-sm font-medium text-text-primary mb-2">
              Alamat
            </label>
            <input
              type="text"
              value={profile.firmAddress}
              onChange={(e) => update('firmAddress', e.target.value)}
              placeholder="Alamat lengkap firma"
              className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
          </div>
        </div>

        {/* Social Media */}
        <div className="space-y-4">
          <div className="flex items-center justify-between mb-4">
            <h3 className="text-sm font-medium text-text-primary">Media Sosial</h3>
            <button
              onClick={addSocial}
              className="flex items-center gap-2 px-3 py-2 bg-lia hover:bg-lia/90 text-white font-medium text-sm rounded-xl transition-colors"
            >
              <Plus size={14} />
              Tambah
            </button>
          </div>
          
          {profile.socials && profile.socials.length > 0 && (
            <div className="space-y-2">
              {profile.socials.map((social) => (
                <div key={social.id} className="flex items-center gap-3 p-3 rounded-xl border border-border">
                  <div className="flex items-center gap-2 text-lia-light">
                    {getSocialIcon(social.type)}
                  </div>
                  <div className="flex-1 min-w-0">
                    <p className="text-sm font-medium text-text-primary capitalize">{social.type}</p>
                    <p className="text-xs text-text-muted truncate">{social.url}</p>
                  </div>
                  <button
                    onClick={() => removeSocial(social.id!)}
                    className="flex items-center gap-1 text-xs text-[#f87171] hover:text-[#ef4444] transition-colors"
                  >
                    <Trash2 size={14} />
                  </button>
                </div>
              ))}
            </div>
          )}

          <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
            <select
              value={newSocial.type}
              onChange={(e) => setNewSocial({ ...newSocial, type: e.target.value as any })}
              className="bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary focus:outline-none focus:border-lia transition-colors"
            >
              <option value="FACEBOOK">Facebook</option>
              <option value="INSTAGRAM">Instagram</option>
              <option value="LINKEDIN">LinkedIn</option>
              <option value="TIKTOK">TikTok</option>
            </select>
            
            <div className="flex gap-2">
              <input
                type="url"
                value={newSocial.url}
                onChange={(e) => setNewSocial({ ...newSocial, url: e.target.value })}
                placeholder="https://..."
                className="flex-1 bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
              />
            </div>
          </div>
        </div>
      </div>

      </div>

      <div>
        <label className="block text-sm font-medium text-text-primary mb-2">Bio / Perihal</label>
        <textarea
          value={profile.bio}
          onChange={(e) => update('bio', e.target.value)}
          rows={4}
          placeholder="Berikan ringkasan tentang latar belakang dan pengkhususan anda..."
          className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors resize-none"
        />
      </div>

      <div>
        <label className="block text-sm font-medium text-text-primary mb-2">Status Ketersediaan</label>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-2">
          {[
            { value: 'AVAILABLE', label: 'Boleh Dihubungi', color: 'text-[#34d399]' },
            { value: 'BUSY', label: 'Sibuk', color: 'text-gold' },
            { value: 'AWAY', label: 'Jauh', color: 'text-[#fb923c]' },
            { value: 'OFFLINE', label: 'Tidak Aktif', color: 'text-text-muted' },
          ].map((status) => (
            <button
              key={status.value}
              onClick={() => update('status', status.value as any)}
              className={`flex items-center justify-center gap-2 p-3 rounded-xl border text-left transition-all text-sm ${
                profile.status === status.value
                  ? 'border-lia-border bg-lia-dim text-text-primary'
                  : 'border-border text-text-secondary hover:border-border-hover'
              }`}
            >
              <div className={`w-4 h-4 rounded-full ${status.color}`} />
              {status.label}
            </button>
          ))}
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label className="block text-sm font-medium text-text-primary mb-2">URL Slug</label>
          <input
            type="text"
            value={profile.slug}
            onChange={(e) => update('slug', e.target.value)}
            placeholder="arif-azmi"
            className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
          />
          <p className="text-xs text-text-muted mt-1">URL untuk profil awam: tanyapeguam.com/[slug]</p>
        </div>

        <div>
          <label className="block text-sm font-medium text-text-primary mb-2">Meta Title (SEO)</label>
          <input
            type="text"
            value={profile.metaTitle}
            onChange={(e) => update('metaTitle', e.target.value)}
            placeholder="Arif Azmi - Peguam Cara Negara | TanyaPeguam"
            className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
          />
        </div>
      </div>

      <div>
        <label className="block text-sm font-medium text-text-primary mb-2">Meta Description (SEO)</label>
        <textarea
          value={profile.metaDescription}
          onChange={(e) => update('metaDescription', e.target.value)}
          rows={2}
          placeholder="Deskripsi profil untuk enjin carian..."
          className="w-full bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors resize-none"
        />
      </div>

      {/* Professional Socials Section */}
      <div className="space-y-6 mt-8">
        <div className="flex items-center gap-2 mb-4">
          <Globe size={20} className="text-lia-light" />
          <h2 className="text-lg font-semibold text-text-primary">Media Sosial Profesional</h2>
        </div>
        
        {/* Existing Socials */}
        {profile.socials && profile.socials.length > 0 && (
          <div className="space-y-2 mb-4">
            {profile.socials.map((social) => (
              <div key={social.id} className="flex items-center gap-3 p-3 rounded-xl border border-border">
                <div className="flex items-center gap-2 text-lia-light">
                  {getSocialIcon(social.type)}
                </div>
                <div className="flex-1 min-w-0">
                  <p className="text-sm font-medium text-text-primary capitalize">{social.type}</p>
                  <p className="text-xs text-text-muted truncate">{social.url}</p>
                </div>
                <button
                  onClick={() => removeSocial(social.id!)}
                  className="flex items-center gap-1 text-xs text-[#f87171] hover:text-[#ef4444] transition-colors"
                >
                  <Trash2 size={14} />
                </button>
              </div>
            ))}
          </div>
        )}

        {/* Add New Social */}
        <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
          <select
            value={newSocial.type}
            onChange={(e) => setNewSocial({ ...newSocial, type: e.target.value as any })}
            className="bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary focus:outline-none focus:border-lia transition-colors"
          >
            <option value="FACEBOOK">Facebook</option>
            <option value="TIKTOK">TikTok</option>
            <option value="INSTAGRAM">Instagram</option>
            <option value="LINKEDIN">LinkedIn</option>
          </select>
          
          <div className="flex gap-2">
            <input
              type="url"
              value={newSocial.url}
              onChange={(e) => setNewSocial({ ...newSocial, url: e.target.value })}
              placeholder="https://..."
              className="flex-1 bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
            <button
              onClick={addSocial}
              disabled={!newSocial.url}
              className="flex items-center gap-1.5 px-4 py-3 bg-lia hover:bg-lia/90 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium text-sm rounded-xl transition-colors"
            >
              <Plus size={14} />
              Tambah
            </button>
          </div>
        </div>
      </div>

      <div className="space-y-4">
        <h3 className="text-sm font-medium text-text-primary">Tetapan Profil</h3>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label className="flex items-center gap-3 p-4 rounded-xl border border-border cursor-pointer hover:border-border-hover">
            <input
              type="checkbox"
              checked={profile.isActive}
              onChange={(e) => update('isActive', e.target.checked)}
              className="w-4 h-4 text-lia border-border rounded focus:ring-lia"
            />
            <div>
              <p className="text-sm font-medium text-text-primary">Profil Aktif</p>
              <p className="text-xs text-text-muted">Tunjukkan profil di laman awam</p>
            </div>
          </label>

          <label className="flex items-center gap-3 p-4 rounded-xl border border-border cursor-pointer hover:border-border-hover">
            <input
              type="checkbox"
              checked={profile.isVerified}
              onChange={(e) => update('isVerified', e.target.checked)}
              className="w-4 h-4 text-lia border-border rounded focus:ring-lia"
            />
            <div>
              <p className="text-sm font-medium text-text-primary">Peguam Disahkan</p>
              <p className="text-xs text-text-muted">Tanda pengesahan rasmi</p>
            </div>
          </label>
        </div>
      </div>

      {/* Social Media Links */}
      <div className="space-y-4">
        <h3 className="text-sm font-medium text-text-primary">Media Sosial & Pautan Web</h3>
        
        {/* Existing Links */}
        {profile.links && profile.links.length > 0 && (
          <div className="space-y-2">
            {profile.links.map((link) => (
              <div key={link.id} className="flex items-center gap-3 p-3 rounded-xl border border-border">
                <div className="flex items-center gap-2 text-lia-light">
                  {getLinkIcon(link.type)}
                </div>
                <div className="flex-1 min-w-0">
                  <p className="text-sm font-medium text-text-primary truncate">{link.label}</p>
                  <p className="text-xs text-text-muted truncate">{link.url}</p>
                </div>
                <button
                  onClick={() => removeLink(link.id!)}
                  className="flex items-center gap-1 text-xs text-[#f87171] hover:text-[#ef4444] transition-colors"
                >
                  <Trash2 size={14} />
                </button>
              </div>
            ))}
          </div>
        )}

        {/* Add New Link */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
          <select
            value={newLink.type}
            onChange={(e) => setNewLink({ ...newLink, type: e.target.value })}
            className="bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary focus:outline-none focus:border-lia transition-colors"
          >
            <option value="WEBSITE">Website</option>
            <option value="WHATSAPP">WhatsApp</option>
            <option value="LINKEDIN">LinkedIn</option>
            <option value="INSTAGRAM">Instagram</option>
            <option value="FACEBOOK">Facebook</option>
            <option value="TWITTER">Twitter</option>
            <option value="YOUTUBE">YouTube</option>
            <option value="EMAIL">Email</option>
            <option value="PHONE">Phone</option>
          </select>
          
          <input
            type="text"
            value={newLink.label}
            onChange={(e) => setNewLink({ ...newLink, label: e.target.value })}
            placeholder="Label (contoh: Laman Web Rasmi)"
            className="bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
          />
          
          <div className="flex gap-2">
            <input
              type="url"
              value={newLink.url}
              onChange={(e) => setNewLink({ ...newLink, url: e.target.value })}
              placeholder="https://..."
              className="flex-1 bg-bg-3 border border-border rounded-xl px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-lia transition-colors"
            />
            <button
              onClick={addLink}
              disabled={!newLink.label || !newLink.url}
              className="flex items-center gap-1.5 px-4 py-3 bg-lia hover:bg-lia/90 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium text-sm rounded-xl transition-colors"
            >
              <Plus size={14} />
              Tambah
            </button>
          </div>
        </div>
      </div>

      <div className="flex justify-end">
        <button
          onClick={submit}
          disabled={isPending}
          className="flex items-center gap-2 bg-lia hover:bg-lia/90 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold px-6 py-3 rounded-xl text-sm transition-colors"
        >
          {isPending ? (
            <>
              <Loader2 size={15} className="animate-spin" />
              Menyimpan...
            </>
          ) : (
            <>
              <Save size={15} />
              Simpan Profil
            </>
          )}
        </button>
      </div>
    </div>
  );
}
